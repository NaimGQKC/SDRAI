# Copy to .env and fill in. Leave a key blank to force that module into mock mode.

# --- Drafting ---
# No Anthropic API key needed: drafts are written by Claude Code via `claude -p`
# (draft_backend: claude_cli in config.yaml). Locally it uses your logged-in Pro
# subscription. Nothing to set here for local runs.
#
# Only for the GitHub Actions cron (unattended): generate a token with
#   claude setup-token
# and store it as the repo secret CLAUDE_CODE_OAUTH_TOKEN (NOT in this file).
#
# Optional fallback only — set draft_backend: api in config.yaml to use it:
# ANTHROPIC_API_KEY=

# --- Research (Perplexity Sonar) ---
PERPLEXITY_API_KEY=

# --- Discovery (People Data Labs) ---
# Free API key at dashboard.peopledatalabs.com (no card). Free tier ~100 records/mo,
# so people_per_day / search_size are kept small in config.yaml.
PDL_API_KEY=

# --- Delivery (Gmail SMTP) ---
# GMAIL_APP_PASSWORD is a 16-char Google App Password (needs 2-Step Verification ON),
# NOT your real password. Steps:
#   1. Google Account -> Security -> turn on 2-Step Verification.
#   2. Google Account -> Security -> App passwords -> create one ("hitlist").
#   3. Paste the 16 chars (spaces optional) below.
# Leave these blank to skip email — the run still writes digest_<date>.html locally.
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
DIGEST_TO=
